always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected ealu = %b | expected inst = %b | expected malu = %b | expected pc = %b | expected wdi = %b | ",ealu_expected_prev,inst_expected_prev,malu_expected_prev,pc_expected_prev,wdi_expected_prev);
	$display("| real ealu = %b | real inst = %b | real malu = %b | real pc = %b | real wdi = %b | ",ealu_prev,inst_prev,malu_prev,pc_prev,wdi_prev);
`endif
	if (
		( ealu_expected_prev[0] !== 1'bx ) && ( ealu_prev[0] !== ealu_expected_prev[0] )
		&& ((ealu_expected_prev[0] !== last_ealu_exp[0]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port ealu[0] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", ealu_expected_prev);
		$display ("     Real value = %b", ealu_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_ealu_exp[0] = ealu_expected_prev[0];
	end
	if (
		( ealu_expected_prev[1] !== 1'bx ) && ( ealu_prev[1] !== ealu_expected_prev[1] )
		&& ((ealu_expected_prev[1] !== last_ealu_exp[1]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port ealu[1] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", ealu_expected_prev);
		$display ("     Real value = %b", ealu_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_ealu_exp[1] = ealu_expected_prev[1];
	end
	if (
		( ealu_expected_prev[2] !== 1'bx ) && ( ealu_prev[2] !== ealu_expected_prev[2] )
		&& ((ealu_expected_prev[2] !== last_ealu_exp[2]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port ealu[2] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", ealu_expected_prev);
		$display ("     Real value = %b", ealu_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_ealu_exp[2] = ealu_expected_prev[2];
	end
	if (
		( ealu_expected_prev[3] !== 1'bx ) && ( ealu_prev[3] !== ealu_expected_prev[3] )
		&& ((ealu_expected_prev[3] !== last_ealu_exp[3]) ||
			on_first_change[1])
	)
