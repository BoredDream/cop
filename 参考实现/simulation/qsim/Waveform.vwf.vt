		$display ("ERROR! Vector Mismatch for output port ealu[3] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", ealu_expected_prev);
		$display ("     Real value = %b", ealu_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_ealu_exp[3] = ealu_expected_prev[3];
	end
	if (
		( ealu_expected_prev[4] !== 1'bx ) && ( ealu_prev[4] !== ealu_expected_prev[4] )
		&& ((ealu_expected_prev[4] !== last_ealu_exp[4]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port ealu[4] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", ealu_expected_prev);
		$display ("     Real value = %b", ealu_prev);
