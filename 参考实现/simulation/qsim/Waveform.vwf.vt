initial 

begin 
$timeformat(-12,3," ps",6);
#1000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module pipelinedcpu_vlg_vec_tst();
// constants                                           
// general purpose registers
reg clk;
reg clrn;
// wires                                               
wire [31:0] ealu;
wire [31:0] inst;
wire [31:0] malu;
wire [31:0] pc;
wire [31:0] wdi;

wire sampler;                             

// assign statements (if any)                          
pipelinedcpu i1 (
// port map - connection between master ports and signals/registers   
	.clk(clk),
	.clrn(clrn),
	.ealu(ealu),
	.inst(inst),
	.malu(malu),
	.pc(pc),
	.wdi(wdi)
);

// clrn
initial
begin
	clrn = 1'b1;
end 

// clk
initial
begin
	clk = 1'b1;
	# 2000;
	repeat(249)
	begin
		clk = 1'b0;
		clk = #2000 1'b1;
		# 2000;
	end
	clk = 1'b0;
end 

pipelinedcpu_vlg_sample_tst tb_sample (
	.clk(clk),
	.clrn(clrn),
	.sampler_tx(sampler)
);

pipelinedcpu_vlg_check_tst tb_out(
	.ealu(ealu),
	.inst(inst),
	.malu(malu),
	.pc(pc),
	.wdi(wdi),
	.sampler_rx(sampler)
);
endmodule

